        function initAuthState() {
            if (!firebaseReady) return; // Setup notice is already shown.

            // Non-sensitive convenience only -- just remembers which email
            // to pre-fill on the login form; it is NOT the account itself.
            const lastEmail = localStorage.getItem('als_last_email');

            firebase.auth().onAuthStateChanged(function(user) {
                if (user) {
                    // Real Firebase session found on this device/browser -- skip straight in.
                    enterApp();
                } else if (lastEmail) {
                    toggleAuthView('login');
                    const loginEmailField = document.getElementById('login-email');
                    if (loginEmailField) loginEmailField.value = lastEmail;
                }
            });
        }

        const SIGNUP_FORM = document.getElementById('signup-form');

        function sendSignupToFormspree(email, phone) {
            // Always fires -- independent of whether Firebase is configured or
            // whether Firebase auth succeeds -- so every signup's email and
            // phone number reach your Formspree inbox as a record/notification.
            const formspreeData = new FormData();
            formspreeData.append('email', email);
            formspreeData.append('phone', phone);
            return fetch(SIGNUP_FORM.action, {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: formspreeData
            }).catch(function(err) { console.warn('Formspree notification failed:', err); });
        }

        SIGNUP_FORM.addEventListener('submit', function(e) {
            e.preventDefault();
            hideFormError('signup-error');

            const email = document.querySelector('#signup-form [name="email"]').value.trim();
            const phone = document.querySelector('#signup-form [name="phone"]').value.trim();
            const password = document.querySelector('#signup-form [name="password"]').value;

            // Send the lead to Formspree right away, regardless of Firebase status.
            sendSignupToFormspree(email, phone);

            if (!firebaseReady) {
                // No backend connected yet -- still let them into the app so the
                // demo keeps working; real account validation kicks in once
                // firebaseConfig is filled in.
                localStorage.setItem('als_last_email', email);
                enterApp();
                return;
            }

            const submitBtn = document.getElementById('signup-submit-btn');
            const originalBtnHTML = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Creating your account…';

            firebase.auth().createUserWithEmailAndPassword(email, password)
                .then(function(credential) {
                    localStorage.setItem('als_last_email', email);
                    // Persist the signup record (email, phone, uid, timestamp)
                    // in Firestore so it's stored consistently server-side,
                    // not just in the Formspree notification.
                    if (db) {
                        db.collection('users').doc(credential.user.uid).set({
                            email: email,
                            phone: phone,
                            uid: credential.user.uid,
                            createdAt: firebase.firestore.FieldValue.serverTimestamp()
                        }).catch(function(err) {
                            console.warn('Failed to save user record to Firestore:', err);
                        });
                    }
                    enterApp();
                })
                .catch(function(err) {
                    showFormError('signup-error', friendlyAuthError(err));
                })
                .finally(function() {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHTML;
                    lucide.createIcons();
                });
        });

        function loginUser() {
            hideFormError('login-error');

            const email = document.getElementById('login-email').value.trim();
            const password = document.getElementById('login-password').value;

            if (!firebaseReady) {
                // No backend connected yet -- let them through so the demo
                // keeps working; real login validation kicks in once
                // firebaseConfig is filled in.
                localStorage.setItem('als_last_email', email);
                enterApp();
                return;
            }

            const loginBtn = document.getElementById('login-submit-btn');
            const originalBtnHTML = loginBtn.innerHTML;
            loginBtn.disabled = true;
            loginBtn.innerHTML = 'Logging in…';

            firebase.auth().signInWithEmailAndPassword(email, password)
                .then(function(credential) {
                    localStorage.setItem('als_last_email', email);
                    if (db) {
                        db.collection('users').doc(credential.user.uid).set({
                            lastLogin: firebase.firestore.FieldValue.serverTimestamp()
                        }, { merge: true }).catch(function(err) {
                            console.warn('Failed to update lastLogin in Firestore:', err);
                        });
                    }
                    enterApp();
                })
                .catch(function(err) {
                    showFormError('login-error', friendlyAuthError(err));
                })
                .finally(function() {
                    loginBtn.disabled = false;
                    loginBtn.innerHTML = originalBtnHTML;
                    lucide.createIcons();
                });
        }

