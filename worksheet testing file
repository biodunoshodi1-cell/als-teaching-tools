                if (isCorrect) {
                    correctCount++;
                    earnedXP += 25;
                }
            });

            globalScore += earnedXP;
            document.getElementById('score-badge').innerText = `${globalScore} XP`;

            // Process dynamic user input fields
            let inputName = document.getElementById('student-name-input').value.trim();
            if (!inputName) inputName = "Excellent Learner";

            const selectedSubjectText = document.getElementById('subject-select').options[document.getElementById('subject-select').selectedIndex].text;
            const selectedYearText = "Year " + document.getElementById('year-select').value;
            const percentageScore = Math.round((correctCount / activeQuestionsSet.length) * 100);

            // Hide normal panels to showcase the certificate
            document.getElementById('worksheet-panel').classList.add('hidden');
            document.getElementById('username-banner').classList.add('hidden');

            // Map variables into certificate elements
            document.getElementById('cert-student-name').innerText = inputName;
            document.getElementById('cert-subject').innerText = selectedSubjectText;
            document.getElementById('cert-year').innerText = selectedYearText;
            document.getElementById('cert-score-percent').innerText = `${percentageScore}%`;
