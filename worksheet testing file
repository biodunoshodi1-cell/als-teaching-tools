            const inputEl = document.getElementById('sprint-input');
            const timerEl = document.getElementById('sprint-timer');
            const scoreEl = document.getElementById('sprint-score');

            const generateSprintEquation = () => {
                numA = Math.floor(Math.random() * 10) + 1;
                numB = Math.floor(Math.random() * 10) + 1;
                correctAnswer = numA + numB;
                equationEl.innerText = `${numA} + ${numB} = ?`;
                inputEl.value = '';
                inputEl.focus();
            };

            inputEl.addEventListener('input', () => {
                if (parseInt(inputEl.value) === correctAnswer) {
                    sprintScore++;
                    globalScore += 5;
                    document.getElementById('score-badge').innerText = `${globalScore} XP`;
                    scoreEl.innerText = sprintScore;
                    generateSprintEquation();
                }
            });

            generateSprintEquation();

            clearInterval(sprintTimer);
            sprintTimer = setInterval(() => {
                timeRemaining--;
                if (timeRemaining <= 0) {
                    clearInterval(sprintTimer);
                    arena.innerHTML = `
                        <div class="text-center space-y-4">
                            <div class="text-3xl">🏁</div>
                            <h4 class="text-xl font-bold">Sprint Complete!</h4>
                            <p class="text-slate-400 text-sm">You earned <span class="text-teal-400 font-bold">${sprintScore * 5} XP</span></p>
                            <button onclick="startMathSprint()" class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-xl text-xs transition-all">Play Again</button>
                        </div>
                    `;
                } else {
                    if (timerEl) timerEl.innerText = `${timeRemaining}s`;
                }
            }, 1000);
        }

        function startMentalMatch() {
            const arena = document.getElementById('active-game-arena');
            arena.classList.remove('hidden');
            clearInterval(sprintTimer);

            let cards = [
                { id: 1, val: "4 + 4", match: "8" }, { id: 2, val: "8", match: "4 + 4" },
                { id: 3, val: "10 - 3", match: "7" }, { id: 4, val: "7", match: "10 - 3" },
                { id: 5, val: "5 x 2", match: "10" }, { id: 6, val: "10", match: "5 x 2" }
            ].sort(() => Math.random() - 0.5);

            let firstSelected = null;
            let secondSelected = null;
            let matchesFound = 0;

            const renderGrid = () => {
                arena.innerHTML = `
                    <div class="space-y-4 w-full max-w-md">
                        <div class="text-center text-xs uppercase tracking-wider text-slate-400">Match equations to solutions</div>
                        <div class="grid grid-cols-3 gap-3" id="match-grid"></div>
                    </div>
                `;
                
                const grid = document.getElementById('match-grid');
                cards.forEach((card, index) => {
                    const cardEl = document.createElement('button');
                    cardEl.className = "h-20 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-sm font-bold text-slate-400 hover:border-teal-500 transition-all focus:outline-none";
                    cardEl.innerText = "?";
                    
                    cardEl.onclick = () => {
                        if (firstSelected !== null && secondSelected !== null) return;
                        if (cardEl.classList.contains('bg-emerald-900')) return;
                        
                        cardEl.innerText = card.val;
                        cardEl.className = "h-20 rounded-xl bg-slate-700 border border-teal-500 flex items-center justify-center text-sm font-bold text-white transition-all focus:outline-none";
                        
                        if(firstSelected === null) {
                            firstSelected = index;
                        } else {
                            if(firstSelected === index) return;
                            secondSelected = index;
                            
                            if(cards[firstSelected].match === cards[secondSelected].val) {
                                matchesFound++;
                                globalScore += 15;
                                document.getElementById('score-badge').innerText = `${globalScore} XP`;
                                
                                setTimeout(() => {
                                    const items = document.querySelectorAll('#match-grid button');
                                    items[firstSelected].className = "h-20 rounded-xl bg-emerald-950 border border-emerald-500 flex items-center justify-center text-sm font-bold text-emerald-400 transition-all focus:outline-none opacity-60 pointer-events-none";
                                    items[secondSelected].className = "h-20 rounded-xl bg-emerald-950 border border-emerald-500 flex items-center justify-center text-sm font-bold text-emerald-400 transition-all focus:outline-none opacity-60 pointer-events-none";
                                    firstSelected = null;
                                    secondSelected = null;
                                    
                                    if(matchesFound === 3) {
                                        arena.innerHTML = `
                                            <div class="text-center space-y-4">
                                                <div class="text-3xl">🎉</div>
                                                <h4 class="text-xl font-bold">Matrix Solved!</h4>
                                                <button onclick="startMentalMatch()" class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-xl text-xs transition-all">Play Again</button>
                                            </div>
                                        `;
                                    }
                                }, 600);
                            } else {
                                setTimeout(() => {
                                    const items = document.querySelectorAll('#match-grid button');
                                    items[firstSelected].className = "h-20 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-sm font-bold text-slate-400 hover:border-teal-500 transition-all";
                                    items[firstSelected].innerText = "?";
                                    cardEl.className = "h-20 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-sm font-bold text-slate-400 hover:border-teal-500 transition-all";
                                    cardEl.innerText = "?";
                                    firstSelected = null;
                                    secondSelected = null;
                                }, 1000);
                            }
                        }
                    };
                    grid.appendChild(cardEl);
                });
            };
            renderGrid();
        }

        lucide.createIcons();
        initAuthState();
    </script>
</body>
</html>

